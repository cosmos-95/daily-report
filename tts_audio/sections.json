[
  [
    {
      "file": "sec000_sent000.mp3",
      "text": "全球要闻日报。",
      "type": "intro"
    },
    {
      "file": "sec000_sent001.mp3",
      "text": "2026年5月30日 · 星期六。",
      "type": "intro"
    },
    {
      "file": "sec000_sent002.mp3",
      "text": "以下是今天的全球重要新闻。",
      "type": "intro"
    }
  ],
  [
    {
      "file": "sec001_sent000.mp3",
      "text": "5月29日晚，Blue Origin的New Glenn火箭在肯尼迪航天中心测试发动机时发生剧烈爆炸，火焰照亮佛罗里达天空。",
      "type": "summary"
    },
    {
      "file": "sec001_sent001.mp3",
      "text": "火箭原定6月4日发射48颗亚马逊Leo卫星，现发射台严重损毁，复飞预计需数月。",
      "type": "summary"
    },
    {
      "file": "sec001_sent002.mp3",
      "text": "此次爆炸直接威胁NASA月球基地计划——首个月球任务Moon Base 1原定搭载Blue Origin的Blue Moon着陆器，而该着陆器需依赖New Glenn发射。",
      "type": "summary"
    },
    {
      "file": "sec001_sent003.mp3",
      "text": "NASA重返月球的整体时间表受严重冲击。",
      "type": "impact"
    },
    {
      "file": "sec001_sent004.mp3",
      "text": "原定2028年的载人登月目标本已紧张，现恐进一步推迟。",
      "type": "impact"
    },
    {
      "file": "sec001_sent005.mp3",
      "text": "亚马逊Leo宽带网络挑战Starlink的进度也将被拖慢，影响全球低轨卫星互联网竞争格局。",
      "type": "impact"
    },
    {
      "file": "sec001_sent006.mp3",
      "text": "关注NASA后续调整公告。",
      "type": "advice"
    },
    {
      "file": "sec001_sent007.mp3",
      "text": "商业航天领域投资者需评估单一发射平台依赖风险。",
      "type": "advice"
    },
    {
      "file": "sec001_sent008.mp3",
      "text": "普通消费者短期内卫星宽带选择不会受明显影响。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec002_sent000.mp3",
      "text": "2026世界智能产业博览会5月28日在天津开幕，超700家参展商展示AI与机器人融合技术。",
      "type": "summary"
    },
    {
      "file": "sec002_sent001.mp3",
      "text": "统计显示中国具身智能产业年增长率超50%，国务院发展研究中心报告预测2035年市场将突破1万亿元人民币（约1465亿美元）。",
      "type": "summary"
    },
    {
      "file": "sec002_sent002.mp3",
      "text": "中国已成为全球最大AI专利持有国，占比60%。",
      "type": "summary"
    },
    {
      "file": "sec002_sent003.mp3",
      "text": "观点对照：国内报道侧重强调自主创新突破和全球市场开放合作；外媒（BBC等）提及核心技术的早期对外依赖以及半导体出口管制对发展速度的潜在影响。",
      "type": "summary"
    },
    {
      "file": "sec002_sent004.mp3",
      "text": "中国在机器人+AI领域的快速产业化将逐步降低进口高端装备依赖，推动国内工厂自动化和医疗机器人成本下降。",
      "type": "impact"
    },
    {
      "file": "sec002_sent005.mp3",
      "text": "制造业从业者需关注技能转型需求。",
      "type": "impact"
    },
    {
      "file": "sec002_sent006.mp3",
      "text": "相关行业从业者关注人形机器人和四足机器人商业化进展，提前了解自动化对岗位的影响，适时学习基础编程和维护技能。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec003_sent000.mp3",
      "text": "OpenAI推出Rosalind Biodefense项目，向通过审查的开发者和美国政府合作伙伴开放GPT-Rosalind模型访问权限，用于推进生物防御和大流行病防范能力建设。",
      "type": "summary"
    },
    {
      "file": "sec003_sent001.mp3",
      "text": "这是OpenAI首次将AI模型专门应用于生物安全领域。",
      "type": "summary"
    },
    {
      "file": "sec003_sent002.mp3",
      "text": "生物安全是AI双刃剑的典型领域——既可用于快速研发疫苗和检测工具，也存在被滥用于生物武器设计的风险。",
      "type": "impact"
    },
    {
      "file": "sec003_sent003.mp3",
      "text": "该计划可能催生新的生物安全监管标准和AI使用规范。",
      "type": "impact"
    },
    {
      "file": "sec003_sent004.mp3",
      "text": "关注生物技术+AI交叉领域的发展，这可能是未来就业和投资的新方向。",
      "type": "advice"
    },
    {
      "file": "sec003_sent005.mp3",
      "text": "普通公众应了解AI在公共卫生领域的应用前景。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec004_sent000.mp3",
      "text": "中国AI公司阶跃星辰（StepFun）发布Step 3.7 Flash模型，这是一款198B参数的MoE（混合专家）多模态模型，在编码和视觉基准测试中取得领先成绩。",
      "type": "summary"
    },
    {
      "file": "sec004_sent001.mp3",
      "text": "模型已上线NVIDIA NIM平台，API定价为每百万输入tokens 0.20美元。",
      "type": "summary"
    },
    {
      "file": "sec004_sent002.mp3",
      "text": "该模型在视觉理解和智能体任务中也展现出较强能力。",
      "type": "summary"
    },
    {
      "file": "sec004_sent003.mp3",
      "text": "国产MoE大模型在benchmark上持续追赶开源顶级水平，意味着开发者将有更多高性价比的AI编码工具选择。",
      "type": "impact"
    },
    {
      "file": "sec004_sent004.mp3",
      "text": "模型价格远低于同等规模海外竞品，有望降低国内AI应用开发门槛。",
      "type": "impact"
    },
    {
      "file": "sec004_sent005.mp3",
      "text": "中小开发团队可关注该模型的API定价和应用生态，尝试在编码辅助、视觉理解场景中部署测试。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec005_sent000.mp3",
      "text": "SK海力士市值突破1万亿美元大关，成为继三星和美光之后第三家加入\"万亿俱乐部\"的存储芯片巨头。",
      "type": "summary"
    },
    {
      "file": "sec005_sent001.mp3",
      "text": "分析师预测AI芯片需求将在2028年前持续超过供给。",
      "type": "summary"
    },
    {
      "file": "sec005_sent002.mp3",
      "text": "HBM高带宽内存作为AI训练的核心硬件，需求爆发是主要驱动力。",
      "type": "summary"
    },
    {
      "file": "sec005_sent003.mp3",
      "text": "存储芯片持续紧俏推高AI服务器成本，可能传导至AI云服务价格。",
      "type": "impact"
    },
    {
      "file": "sec005_sent004.mp3",
      "text": "对普通用户而言，AI产品使用成本短期内不会明显下降。",
      "type": "impact"
    },
    {
      "file": "sec005_sent005.mp3",
      "text": "关注HBM产业链上下游投资机会。",
      "type": "advice"
    },
    {
      "file": "sec005_sent006.mp3",
      "text": "AI应用开发者在预算规划中需考虑算力成本趋势。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec006_sent000.mp3",
      "text": "特朗普在白宫战情室召集高层会议，试图对伊朗停火框架做出\"最终决定\"，但会后未宣布任何进展。",
      "type": "summary"
    },
    {
      "file": "sec006_sent001.mp3",
      "text": "特朗普要求伊朗永不拥有核武器、重新开放霍尔木兹海峡。",
      "type": "summary"
    },
    {
      "file": "sec006_sent002.mp3",
      "text": "伊朗最高领袖顾问指责特朗普\"第三次背叛外交\"，称美方在谅解备忘录中并无销毁核材料条款。",
      "type": "summary"
    },
    {
      "file": "sec006_sent003.mp3",
      "text": "此前双方曾同意延长停火60天并启动核谈，但迄今无实质成果。",
      "type": "summary"
    },
    {
      "file": "sec006_sent004.mp3",
      "text": "观点对照：美媒侧重特朗普设定的\"红线\"和强硬谈判策略；伊朗官方媒体强调美方封锁仍在持续，指责美方提出过度要求；国内报道关注霍尔木兹海峡通航安全对中国能源进口的影响。",
      "type": "summary"
    },
    {
      "file": "sec006_sent005.mp3",
      "text": "霍尔木兹海峡局势直接影响全球油价和中国能源安全。",
      "type": "impact"
    },
    {
      "file": "sec006_sent006.mp3",
      "text": "若美伊谈判破裂、封锁持续，国内油价可能再次上涨。",
      "type": "impact"
    },
    {
      "file": "sec006_sent007.mp3",
      "text": "关注美伊谈判进展，油价敏感期可适当调整出行方式和能源消费。",
      "type": "advice"
    },
    {
      "file": "sec006_sent008.mp3",
      "text": "投资者注意能源板块波动风险。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec007_sent000.mp3",
      "text": "一枚俄罗斯无人机撞击罗马尼亚一栋公寓楼，造成两人受伤。",
      "type": "summary"
    },
    {
      "file": "sec007_sent001.mp3",
      "text": "罗马尼亚军方紧急出动两架F-16战斗机和一架直升机。",
      "type": "summary"
    },
    {
      "file": "sec007_sent002.mp3",
      "text": "北约和欧盟均强烈谴责，称这是对北约领土的侵犯。",
      "type": "summary"
    },
    {
      "file": "sec007_sent003.mp3",
      "text": "分析认为该无人机可能在乌克兰上空被防空火力击中后偏离航线。",
      "type": "summary"
    },
    {
      "file": "sec007_sent004.mp3",
      "text": "俄乌战火首次实质触及北约成员国居民区，可能促使北约调整东翼防御部署。",
      "type": "impact"
    },
    {
      "file": "sec007_sent005.mp3",
      "text": "对全球安全格局而言，事件标志着冲突升级风险增加。",
      "type": "impact"
    },
    {
      "file": "sec007_sent006.mp3",
      "text": "对普通人而言，需关注能源和粮食价格是否会因地缘紧张再次波动。",
      "type": "impact"
    },
    {
      "file": "sec007_sent007.mp3",
      "text": "关注北约后续反应。",
      "type": "advice"
    },
    {
      "file": "sec007_sent008.mp3",
      "text": "若局势升级，避险资产（黄金、美元）可能短期走强。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec008_sent000.mp3",
      "text": "联邦法官暂时阻止特朗普政府设立18亿美元\"反武器化\"基金。",
      "type": "summary"
    },
    {
      "file": "sec008_sent001.mp3",
      "text": "该基金源自此前与司法部达成的和解协议，用于赔偿声称被联邦政府\"武器化\"对待的个人。",
      "type": "summary"
    },
    {
      "file": "sec008_sent002.mp3",
      "text": "前1月6日调查检察官提起诉讼，称该基金可能被用于报复政治对手。",
      "type": "summary"
    },
    {
      "file": "sec008_sent003.mp3",
      "text": "法官命令白宫在进一步法律辩论前不得采取任何行动。",
      "type": "summary"
    },
    {
      "file": "sec008_sent004.mp3",
      "text": "此案凸显美国司法行政分支之间的深层对立。",
      "type": "impact"
    },
    {
      "file": "sec008_sent005.mp3",
      "text": "基金若最终实施，可能为政治报复提供资金渠道，动摇法治基础。",
      "type": "impact"
    },
    {
      "file": "sec008_sent006.mp3",
      "text": "对中国读者而言，理解美国国内政治裂痕有助于判断其政策的可预测性。",
      "type": "impact"
    },
    {
      "file": "sec008_sent007.mp3",
      "text": "关注后续法庭裁决结果。",
      "type": "advice"
    },
    {
      "file": "sec008_sent008.mp3",
      "text": "此案折射的法治风险对国际贸易和投资环境有间接影响。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec009_sent000.mp3",
      "text": "美国战争部长赫格塞斯在新加坡香格里拉对话会上表示美国不会\"背弃\"亚洲盟友，但期望盟友增加国防开支。",
      "type": "summary"
    },
    {
      "file": "sec009_sent001.mp3",
      "text": "在提问环节他被问及美国对亚太承诺的可信度，包括进一步的军售计划。",
      "type": "summary"
    },
    {
      "file": "sec009_sent002.mp3",
      "text": "这是美国更名\"战争部\"后首次在该场合发表演说。",
      "type": "summary"
    },
    {
      "file": "sec009_sent003.mp3",
      "text": "观点对照：美方强调同盟体系不可动摇但要求盟友\"付费\"；中国国内媒体可能关注美国在亚太增强军力部署对中国周边安全环境的影响。",
      "type": "summary"
    },
    {
      "file": "sec009_sent004.mp3",
      "text": "美国亚太战略要求的\"盟友分担\"意味着日韩澳等国防预算将持续增长，可能牵动地区军备竞赛。",
      "type": "impact"
    },
    {
      "file": "sec009_sent005.mp3",
      "text": "对中国而言，周边安全环境面临更多不确定性。",
      "type": "impact"
    },
    {
      "file": "sec009_sent006.mp3",
      "text": "关注南海、台海局势动态。",
      "type": "advice"
    },
    {
      "file": "sec009_sent007.mp3",
      "text": "区域紧张可能短期影响股市情绪，但对普通生活影响有限。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec010_sent000.mp3",
      "text": "加纳议会经过激烈辩论后通过《人类性权利与家庭价值观法案2025》（即反LGBTQ+法案），法案将同性恋行为定为刑事犯罪，可判处监禁。",
      "type": "summary"
    },
    {
      "file": "sec010_sent001.mp3",
      "text": "此前加纳已是非洲同性恋非法的国家之一，新法案进一步收紧了相关条款。",
      "type": "summary"
    },
    {
      "file": "sec010_sent002.mp3",
      "text": "法案可能引发西方援助国和投资者的反应，对加纳外援和投资环境产生间接影响。",
      "type": "impact"
    },
    {
      "file": "sec010_sent003.mp3",
      "text": "LGBTQ+群体的人权状况引发国际关注。",
      "type": "impact"
    },
    {
      "file": "sec010_sent004.mp3",
      "text": "关注该法案是否获得总统签署。",
      "type": "advice"
    },
    {
      "file": "sec010_sent005.mp3",
      "text": "对计划前往加纳的中国公民，需了解当地法律，避免触碰红线。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec011_sent000.mp3",
      "text": "肯塔基州Breathitt县学区从Meta等社交媒体公司获得约2700万美元和解金，以了结关于社交媒体对青少年造成心理伤害的诉讼。",
      "type": "summary"
    },
    {
      "file": "sec011_sent001.mp3",
      "text": "其中Meta单独赔偿900万美元。",
      "type": "summary"
    },
    {
      "file": "sec011_sent002.mp3",
      "text": "案件在衡平法院开庭前几周达成和解，是迄今学区起诉社交媒体公司的最大和解案例之一。",
      "type": "summary"
    },
    {
      "file": "sec011_sent003.mp3",
      "text": "该案为全美其他学区起诉社交媒体平台提供了判例参考。",
      "type": "impact"
    },
    {
      "file": "sec011_sent004.mp3",
      "text": "国内类似诉讼也在增多，青少年网络保护问题日益受到社会关注。",
      "type": "impact"
    },
    {
      "file": "sec011_sent005.mp3",
      "text": "家长需警惕社交媒体对未成年人的潜在负面影响。",
      "type": "impact"
    },
    {
      "file": "sec011_sent006.mp3",
      "text": "控制青少年屏幕时间和社交媒体使用时长。",
      "type": "advice"
    },
    {
      "file": "sec011_sent007.mp3",
      "text": "关注国内《未成年人网络保护条例》执行情况。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec012_sent000.mp3",
      "text": "西班牙首相桑切斯在执政八年后遭遇最严重的政治生存危机。",
      "type": "summary"
    },
    {
      "file": "sec012_sent001.mp3",
      "text": "同僚和亲属的多项腐败调查使这位社会党领袖陷入困境。",
      "type": "summary"
    },
    {
      "file": "sec012_sent002.mp3",
      "text": "包括妻子涉嫌商业腐败在内的多起案件正在调查中，反对派呼吁提前大选。",
      "type": "summary"
    },
    {
      "file": "sec012_sent003.mp3",
      "text": "西班牙政局不稳可能影响欧盟内部决策效率。",
      "type": "impact"
    },
    {
      "file": "sec012_sent004.mp3",
      "text": "对在南欧有投资或贸易的中国企业而言，需关注政策连续性风险。",
      "type": "impact"
    },
    {
      "file": "sec012_sent005.mp3",
      "text": "关注西班牙是否提前大选。",
      "type": "advice"
    },
    {
      "file": "sec012_sent006.mp3",
      "text": "目前对普通中国游客影响有限。",
      "type": "advice"
    }
  ],
  [
    {
      "file": "sec013_sent000.mp3",
      "text": "英格兰部分地区因创纪录高温和干燥春季面临缺水危机。",
      "type": "summary"
    },
    {
      "file": "sec013_sent001.mp3",
